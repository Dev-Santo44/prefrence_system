# Database (Supabase PostgreSQL)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_supabase_password
DB_HOST=db.your-project.supabase.co
DB_PORT=5432

# Django Settings
DJANGO_SECRET_KEY=django-insecure-your-secret-key-here
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,your-app.vercel.app

# API Keys
GOLDAPI_KEY=your_goldapi_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Cloud Storage (Media Storage)
GS_BUCKET_NAME=your_bucket_name
GS_PROJECT_ID=your_project_id
GS_CREDENTIALS_JSON='{"type": "service_account", ...}' # Full JSON content
